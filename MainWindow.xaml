<Window x:Class="UniversalVideoDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:UniversalVideoDownloader.ViewModels"
        mc:Ignorable="d"
        Title="Universal Video Downloader - Download Manager"
        Width="1100"
        Height="720"
        MinWidth="960"
        MinHeight="640"
        Background="#0F172A"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="Resources/Lang.en.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Custom Rounded TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Custom Modern Buttons -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#475569"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#334155"/>
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Sidebar Buttons -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedForeground}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ProgressBar Style -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Name="TemplateRoot">
                            <Border CornerRadius="4" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}"/>
                            <Grid HorizontalAlignment="Left" Margin="0">
                                <Border x:Name="PART_Indicator" CornerRadius="4" Background="{TemplateBinding Foreground}"/>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}" BorderBrush="#1E293B" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand Header -->
                <StackPanel Grid.Row="0" Margin="24,24,24,32">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource AccentBrush}" Margin="0,0,8,0">
                            <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" Fill="White" Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="UVD Manager" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextForeground}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="v1.0.0 Stable" FontSize="11" Foreground="{DynamicResource TextMutedForeground}"/>
                </StackPanel>

                <!-- Sidebar Buttons -->
                <StackPanel Grid.Row="1">
                    <!-- Download -->
                    <Button Command="{Binding ChangeTabCommand}" CommandParameter="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4E5;" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Downloads" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- History -->
                    <Button Command="{Binding ChangeTabCommand}" CommandParameter="1" Margin="0,4,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4DC;" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="History" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Settings -->
                    <Button Command="{Binding ChangeTabCommand}" CommandParameter="2" Margin="0,4,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" FontSize="16" Margin="0,0,12,0"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- About Tab Button at the bottom -->
                <Button Grid.Row="2" Command="{Binding ChangeTabCommand}" CommandParameter="3" Margin="0,0,0,24">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                    <Setter Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x2139;" FontSize="16" Margin="0,0,12,0"/>
                        <TextBlock Text="About" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Right Main Panel (Multi-tabbed Content switching based on SelectedTabIndex) -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Views -->
            <TabControl SelectedIndex="{Binding SelectedTabIndex}" BorderThickness="0" Background="Transparent" Grid.Row="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </Style>
                </TabControl.ItemContainerStyle>

                <!-- Tab 0: Downloads -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1.4*"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Top row: Config and Metadata -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="1.2*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Column: Input and configuration parameters -->
                            <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource Lang_DownloadConfig}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,16"/>

                                        <!-- Video URL -->
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="{DynamicResource Lang_VideoUrl}" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <TextBox Style="{StaticResource ModernTextBox}" 
                                                     Text="{Binding VideoUrl, UpdateSourceTrigger=PropertyChanged}" 
                                                     Height="40"/>
                                        </StackPanel>

                                        <!-- Quality Selector -->
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="{DynamicResource Lang_Quality}" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <ComboBox SelectedValue="{Binding SelectedQuality}" SelectedValuePath="Content">
                                                <ComboBoxItem Content="Best"/>
                                                <ComboBoxItem Content="2160"/>
                                                <ComboBoxItem Content="1440"/>
                                                <ComboBoxItem Content="1080"/>
                                                <ComboBoxItem Content="720"/>
                                                <ComboBoxItem Content="480"/>
                                                <ComboBoxItem Content="360"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Cookies Source Selector -->
                                        <StackPanel Margin="0,0,0,16">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Text="{DynamicResource Lang_CookiesSource}" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold"/>
                                                <TextBlock Text=" (Bypasses 403 blocks)" Foreground="{DynamicResource SuccessBrush}" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ComboBox SelectedValue="{Binding SelectedBrowser}" SelectedValuePath="Content">
                                                <ComboBoxItem Content="None"/>
                                                <ComboBoxItem Content="Chrome"/>
                                                <ComboBoxItem Content="Edge"/>
                                                <ComboBoxItem Content="Firefox"/>
                                                <ComboBoxItem Content="Brave"/>
                                                <ComboBoxItem Content="Opera"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Advanced Options Checkboxes -->
                                        <StackPanel Margin="0,0,0,20">
                                            <CheckBox Content="Download as Audio Only (MP3)" Foreground="{DynamicResource TextForeground}" IsChecked="{Binding IsAudioOnly}" Margin="0,0,0,8" FontSize="13"/>
                                            <CheckBox Content="Write and Embed Subtitles" Foreground="{DynamicResource TextForeground}" IsChecked="{Binding WriteSubtitles}" FontSize="13"/>
                                        </StackPanel>

                                        <!-- Download folder path selection -->
                                        <StackPanel Margin="0,0,0,24">
                                            <TextBlock Text="{DynamicResource Lang_DestinationPath}" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Style="{StaticResource ModernTextBox}" 
                                                         Text="{Binding DownloadPath, UpdateSourceTrigger=PropertyChanged}" 
                                                         Height="40" 
                                                         IsReadOnly="True"
                                                         Grid.Column="0"/>
                                                <Button Style="{StaticResource SecondaryButton}" 
                                                        Content="Browse" 
                                                        Command="{Binding BrowseFolderCommand}"
                                                        Height="40" 
                                                        Padding="12,0"
                                                        Grid.Column="2"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Control Buttons -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Style="{StaticResource SecondaryButton}" 
                                                    Content="{DynamicResource Lang_AnalyzeUrl}" 
                                                    Command="{Binding AnalyzeCommand}"
                                                    Height="45"
                                                    Grid.Column="0"/>
                                            <Button Style="{StaticResource ModernButton}" 
                                                    Content="{DynamicResource Lang_DownloadVideo}" 
                                                    Command="{Binding DownloadCommand}"
                                                    Height="45"
                                                    Grid.Column="2"/>
                                        </Grid>

                                        <Button Style="{StaticResource DangerButton}" 
                                                Content="Cancel Current Operation" 
                                                Command="{Binding CancelCommand}"
                                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                                                Height="40"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- Right Column: Video information details & Download progress feedback -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Video Metadata Card -->
                                <Border Grid.Row="0" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="VIDEO DETAILS" Grid.Row="0" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,12"/>

                                        <Grid Grid.Row="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="150"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Thumbnail -->
                                            <Border Grid.Row="0" Background="#020617" CornerRadius="8" BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1" ClipToBounds="True">
                                                <Grid>
                                                    <TextBlock Text="No Thumbnail Available" 
                                                               Foreground="{DynamicResource TextMutedForeground}" 
                                                               HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding HasNoThumbnail, Converter={StaticResource BoolToVis}}"/>
                                                    <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"
                                                           Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Text Metadata -->
                                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="Title:" Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource TextMutedForeground}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Title}" Grid.Row="0" Grid.Column="2" Foreground="{DynamicResource TextForeground}" TextWrapping="Wrap" FontWeight="SemiBold"/>

                                                    <TextBlock Text="Source:" Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource TextMutedForeground}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Website}" Grid.Row="2" Grid.Column="2" Foreground="{DynamicResource TextForeground}"/>

                                                    <TextBlock Text="Duration:" Grid.Row="4" Grid.Column="0" Foreground="{DynamicResource TextMutedForeground}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Duration}" Grid.Row="4" Grid.Column="2" Foreground="{DynamicResource TextForeground}"/>

                                                    <TextBlock Text="Resolution:" Grid.Row="6" Grid.Column="0" Foreground="{DynamicResource TextMutedForeground}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Resolution}" Grid.Row="6" Grid.Column="2" Foreground="{DynamicResource TextForeground}"/>
                                                </Grid>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Progress Card -->
                                <Border Grid.Row="2" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock Text="DOWNLOAD PROGRESS" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0:F1}%}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextForeground}" HorizontalAlignment="Right"/>
                                        </Grid>

                                        <ProgressBar Style="{StaticResource ModernProgressBar}" Value="{Binding ProgressPercentage}" Margin="0,0,0,12"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="Speed: " Foreground="{DynamicResource TextMutedForeground}"/>
                                                <TextBlock Text="{Binding DownloadSpeed}" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock Text="ETA: " Foreground="{DynamicResource TextMutedForeground}"/>
                                                <TextBlock Text="{Binding Eta}" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- Bottom row: Download Queue Panel -->
                        <Border Grid.Row="2" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header actions -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="{DynamicResource Lang_QueueManager}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="{DynamicResource Lang_AddQueue}" Command="{Binding AddToQueueCommand}" Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="0,0,8,0" FontSize="11"/>
                                        <Button Content="{DynamicResource Lang_StartQueue}" Command="{Binding StartQueueCommand}" Style="{StaticResource ModernButton}" Padding="10,4" Margin="0,0,8,0" FontSize="11"/>
                                        <Button Content="{DynamicResource Lang_PauseQueue}" Command="{Binding PauseQueueCommand}" Style="{StaticResource DangerButton}" Padding="10,4" FontSize="11"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Queue List -->
                                <ListView Grid.Row="1" ItemsSource="{Binding DownloadQueue}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextForeground}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="8,6" Background="Transparent">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="155"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Title & URL -->
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextForeground}" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Url}" FontSize="10" Foreground="{DynamicResource TextMutedForeground}" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                                    </StackPanel>

                                                    <!-- Progress Bar -->
                                                    <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                        <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100" Height="8" Foreground="{DynamicResource AccentBrush}" Background="#1E293B" BorderThickness="0"/>
                                                        <TextBlock Text="{Binding Progress, StringFormat='{}{0:F1}%'}" FontSize="8" Foreground="{DynamicResource TextForeground}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-12,0,0"/>
                                                    </Grid>

                                                    <!-- Status Badge -->
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="6,3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#64748B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                        <Setter Property="Background" Value="#38BDF8"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                        <Setter Property="Background" Value="#10B981"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                        <Setter Property="Background" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                        <Setter Property="Background" Value="#F59E0B"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Foreground="White" FontSize="9" FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="Pending"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                            <Setter Property="Text" Value="Downloading"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                            <Setter Property="Text" Value="Completed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                            <Setter Property="Text" Value="Failed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                            <Setter Property="Text" Value="Paused"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>

                                                    <!-- Speed -->
                                                    <TextBlock Text="{Binding Speed}" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextForeground}"/>

                                                    <!-- ETA -->
                                                    <TextBlock Text="{Binding ETA}" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextMutedForeground}"/>

                                                    <!-- Actions -->
                                                    <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <!-- Pause Button (⏸) -->
                                                        <Button Content="&#x23F8;" 
                                                                Command="{Binding DataContext.PauseItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}" 
                                                                CommandParameter="{Binding}" 
                                                                Style="{StaticResource SecondaryButton}" 
                                                                Padding="6,2" FontSize="11" Margin="0,0,4,0" ToolTip="Pause"/>
                                                        <!-- Resume Button (▶) -->
                                                        <Button Content="&#x25B6;" 
                                                                Command="{Binding DataContext.ResumeItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}" 
                                                                CommandParameter="{Binding}" 
                                                                Style="{StaticResource SecondaryButton}" 
                                                                Padding="6,2" FontSize="11" Margin="0,0,4,0" ToolTip="Resume"/>
                                                        <!-- Retry Button (↻) -->
                                                        <Button Content="&#x21BB;" 
                                                                Command="{Binding DataContext.RetryItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}" 
                                                                CommandParameter="{Binding}" 
                                                                Style="{StaticResource SecondaryButton}" 
                                                                Padding="6,2" FontSize="11" Margin="0,0,4,0" ToolTip="Retry"/>
                                                        <!-- Logs Button (📝) -->
                                                        <Button Content="&#x1F4DD;" 
                                                                Command="{Binding DataContext.ShowLogWindowCommand, RelativeSource={RelativeSource AncestorType=ListView}}" 
                                                                CommandParameter="{Binding}" 
                                                                Style="{StaticResource SecondaryButton}" 
                                                                Padding="6,2" FontSize="11" Margin="0,0,4,0" ToolTip="Logs"/>
                                                        <!-- Remove Button (❌) -->
                                                        <Button Content="&#x274C;" 
                                                                Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}" 
                                                                CommandParameter="{Binding}" 
                                                                Style="{StaticResource DangerButton}" 
                                                                Padding="6,2" FontSize="11" ToolTip="Remove"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Tab 1: History -->
                <TabItem>
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="DOWNLOAD HISTORY" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextForeground}" VerticalAlignment="Center" Grid.Column="0"/>
                                
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Text="{Binding HistorySearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32"
                                         FontSize="12"
                                         Padding="10,6"
                                         VerticalAlignment="Center"
                                         Grid.Column="2"
                                         ToolTip="Type here to search downloaded videos..."/>
                                         
                                <Button Style="{StaticResource DangerButton}" 
                                        Content="Clear History" 
                                        Command="{Binding ClearHistoryCommand}"
                                        Grid.Column="4"
                                        Padding="12,6"
                                        Height="32"
                                        VerticalAlignment="Center"
                                        FontSize="12"/>
                            </Grid>

                            <!-- ListView of download logs -->
                            <ListView Grid.Row="1" 
                                      ItemsSource="{Binding HistoryItems}" 
                                      Background="Transparent" 
                                      BorderThickness="0"
                                      Foreground="{DynamicResource TextForeground}"
                                      Name="HistoryListView">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="12,10" Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Title -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextForeground}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Url}" FontSize="11" Foreground="{DynamicResource TextMutedForeground}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <!-- Website source -->
                                                <TextBlock Text="{Binding Website}" Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedForeground}"/>

                                                <!-- Size -->
                                                <TextBlock Text="{Binding FileSize}" Grid.Column="2" VerticalAlignment="Center" Foreground="{DynamicResource TextForeground}"/>

                                                <!-- Date -->
                                                <TextBlock Text="{Binding DownloadDate, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Grid.Column="3" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedForeground}"/>

                                                <!-- Status Badge -->
                                                <Border Grid.Column="4" CornerRadius="4" Padding="6,3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#10B981"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                    <Setter Property="Background" Value="#EF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Foreground="White" FontSize="10" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Success"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                        <Setter Property="Text" Value="Failed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Actions for selected history item -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" 
                                        Content="Open File Location" 
                                        Command="{Binding OpenFolderCommand}"
                                        CommandParameter="{Binding ElementName=HistoryListView, Path=SelectedItem}"
                                        Padding="16,8"
                                        FontSize="13"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Tab 2: Settings -->
                <TabItem>
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="APPLICATION SETTINGS" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextForeground}" Margin="0,0,0,20"/>

                                <!-- Default Download path -->
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Default Download Directory" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Style="{StaticResource ModernTextBox}" 
                                                 Text="{Binding DownloadPath, UpdateSourceTrigger=PropertyChanged}" 
                                                 Height="40" 
                                                 IsReadOnly="True"
                                                 Grid.Column="0"/>
                                        <Button Style="{StaticResource SecondaryButton}" 
                                                Content="Browse" 
                                                Command="{Binding BrowseFolderCommand}"
                                                Height="40" 
                                                Padding="12,0"
                                                Grid.Column="2"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Options grid -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Default Quality -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Default Download Quality" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox SelectedValue="{Binding SelectedQuality}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="Best"/>
                                            <ComboBoxItem Content="2160"/>
                                            <ComboBoxItem Content="1440"/>
                                            <ComboBoxItem Content="1080"/>
                                            <ComboBoxItem Content="720"/>
                                            <ComboBoxItem Content="480"/>
                                            <ComboBoxItem Content="360"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Default Browser Cookies -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Default Browser Cookies Source" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox SelectedValue="{Binding SelectedBrowser}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="None"/>
                                            <ComboBoxItem Content="Chrome"/>
                                            <ComboBoxItem Content="Edge"/>
                                            <ComboBoxItem Content="Firefox"/>
                                            <ComboBoxItem Content="Brave"/>
                                            <ComboBoxItem Content="Opera"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- Thread count and aria2 settings -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Max Download Threads (Recommended: 8-16)" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding Threads, UpdateSourceTrigger=PropertyChanged}" Height="36"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <CheckBox Content="Enable aria2 Download Accelerator (Fast Multithreaded)" 
                                                  Foreground="{DynamicResource TextForeground}" 
                                                  IsChecked="{Binding UseAria2}" 
                                                  FontSize="13" 
                                                  Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Advanced Settings (Concurrency, Clipboard, Tray) -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Max Concurrent Downloads (Queue)" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBox Style="{StaticResource ModernTextBox}" Text="{Binding MaxConcurrentDownloads, UpdateSourceTrigger=PropertyChanged}" Height="36"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <CheckBox Content="Enable Clipboard Monitor (Auto-detect Video Links)" 
                                                  Foreground="{DynamicResource TextForeground}" 
                                                  IsChecked="{Binding EnableClipboardMonitor}" 
                                                  FontSize="13" 
                                                  Margin="0,4,0,8"/>
                                        <CheckBox Content="Minimize to System Tray on Close" 
                                                  Foreground="{DynamicResource TextForeground}" 
                                                  IsChecked="{Binding MinimizeToTray}" 
                                                  FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Scheduler Settings -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <CheckBox Content="Enable Download Scheduler (Starts queue at set time)" 
                                                  Foreground="{DynamicResource TextForeground}" 
                                                  IsChecked="{Binding SchedulerEnabled}" 
                                                  FontWeight="SemiBold"
                                                  FontSize="13" 
                                                  Margin="0,0,0,8"/>
                                        <TextBox Style="{StaticResource ModernTextBox}" 
                                                 Text="{Binding SchedulerTime, UpdateSourceTrigger=PropertyChanged}" 
                                                 Height="36" 
                                                 ToolTip="Enter time format HH:mm e.g. 02:00"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Action on Queue Completion" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox SelectedValue="{Binding SelectedSchedulerAction}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="None"/>
                                            <ComboBoxItem Content="Shutdown"/>
                                            <ComboBoxItem Content="Sleep"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- Speed Limiter settings -->
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Download Speed Limiter (Bandwidth throttling)" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox SelectedValue="{Binding SelectedSpeedLimit}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="Unlimited"/>
                                            <ComboBoxItem Content="500 KB/s"/>
                                            <ComboBoxItem Content="1 MB/s"/>
                                            <ComboBoxItem Content="2 MB/s"/>
                                            <ComboBoxItem Content="5 MB/s"/>
                                            <ComboBoxItem Content="10 MB/s"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- Style & Interface Settings (Theme, Language) -->
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Application Theme" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox SelectedValue="{Binding SelectedTheme}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="Dark"/>
                                            <ComboBoxItem Content="Light"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Application Language" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox SelectedValue="{Binding SelectedLanguage}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="English" Tag="en"/>
                                            <ComboBoxItem Content="Tiếng Việt" Tag="vi"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <Button Style="{StaticResource ModernButton}" 
                                        Content="Save Current Settings" 
                                        Command="{Binding SaveSettingsCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="20,10"
                                        Margin="0,0,0,32"/>

                                <!-- Dependency Status Card -->
                                <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="16" Background="#0B132B">
                                    <StackPanel>
                                        <TextBlock Text="DEPENDENCY TOOL MANAGER" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,16"/>
                                        
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- yt-dlp -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsYtDlpInstalled}" Value="True">
                                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsYtDlpInstalled}" Value="False">
                                                                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="yt-dlp Core: " Foreground="{DynamicResource TextMutedForeground}"/>
                                                <TextBlock Text="{Binding YtDlpStatus}" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <!-- ffmpeg -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFFmpegInstalled}" Value="True">
                                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsFFmpegInstalled}" Value="False">
                                                                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="FFmpeg (Merge): " Foreground="{DynamicResource TextMutedForeground}"/>
                                                <TextBlock Text="{Binding FfmpegStatus}" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <!-- aria2 -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAria2Installed}" Value="True">
                                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsAria2Installed}" Value="False">
                                                                    <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="aria2 (Accelerator): " Foreground="{DynamicResource TextMutedForeground}"/>
                                                <TextBlock Text="{Binding Aria2Status}" Foreground="{DynamicResource TextForeground}" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Grid>

                                        <Button Style="{StaticResource SecondaryButton}" 
                                                Content="Download / Update All Missing Dependencies" 
                                                Command="{Binding InstallDependenciesCommand}"
                                                Padding="16,8"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <!-- Tab 3: About -->
                <TabItem>
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="24">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,32">
                                <Border Width="72" Height="72" CornerRadius="18" Background="{DynamicResource AccentBrush}" Margin="0,0,0,16" HorizontalAlignment="Center">
                                    <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" Fill="White" Stretch="Uniform" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                                <TextBlock Text="Universal Video Downloader" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextForeground}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Version 1.0.0 Stable" FontSize="14" Foreground="{DynamicResource TextMutedForeground}" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                                <TextBlock Text="A lightweight, high-performance download manager leveraging the power of yt-dlp, FFmpeg, and aria2." 
                                           Foreground="{DynamicResource TextForeground}" 
                                           FontSize="13" 
                                           HorizontalAlignment="Center" 
                                           TextAlignment="Center"
                                           MaxWidth="450"
                                           Margin="0,0,0,16"/>

                                <TextBlock Text="Developed by KAKA91 using C#, WPF (.NET 10), and CommunityToolkit.Mvvm" 
                                           Foreground="{DynamicResource TextMutedForeground}" 
                                           FontSize="12" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,20"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                                    <Button Style="{StaticResource SecondaryButton}" 
                                            Content="Check for Updates" 
                                            Command="{Binding CheckForUpdatesCommand}" 
                                            Padding="12,6" 
                                            Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding UpdateStatusText}" 
                                               Foreground="{DynamicResource TextMutedForeground}" 
                                               VerticalAlignment="Center" 
                                               FontSize="12"/>
                                </StackPanel>

                                <Border BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="0,16,0,0" Width="300">
                                    <TextBlock Text="Licensed under the MIT License." Foreground="{DynamicResource TextMutedForeground}" FontSize="12" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- Bottom Status Indicator -->
            <StatusBar Grid.Row="1" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#334155" Padding="0,12,0,0" Margin="0,16,0,0">
                <StatusBarItem Padding="0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextMutedForeground}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Grid>
</Window>

