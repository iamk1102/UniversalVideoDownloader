<Window x:Class="UniversalVideoDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Universal Video Downloader"
        Width="1100"
        Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Video URL -->

        <TextBlock
        Grid.Row="0"
        Text="Video URL"
        FontSize="18"
        FontWeight="SemiBold"
        Margin="0,0,0,10"/>

        <!-- URL -->

        <TextBox
        Grid.Row="1"
        Height="42"
        FontSize="15"
        Padding="10"
        VerticalContentAlignment="Center"
        Text="https://"/>

        <!-- Buttons -->

        <StackPanel
        Grid.Row="2"
        Orientation="Horizontal"
        Margin="0,15,0,10">

            <Button
            Content="Analyze"
            Width="130"
            Height="42"
            Margin="0,0,12,0"/>

            <Button
            Content="Download"
            Width="130"
            Height="42"/>

        </StackPanel>

        <!-- Separator -->

        <Separator
        Grid.Row="3"
        Margin="0,10"/>

        <!-- Video Information -->

        <StackPanel Grid.Row="4">

            <TextBlock
            Text="Video Information"
            FontSize="18"
            FontWeight="SemiBold"
            Margin="0,10"/>

            <Grid Margin="0,10,0,0">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="150"/>

                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>

                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>

                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Title :" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Website :" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Duration :" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Resolution :" FontWeight="SemiBold"/>

                <TextBlock Grid.Row="0" Grid.Column="1" Text="-"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="-"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="-"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="-"/>

            </Grid>

        </StackPanel>

        <!-- Status -->

        <StatusBar Grid.Row="7">

            <TextBlock Text="Ready"/>

        </StatusBar>

    </Grid>
</Window>
