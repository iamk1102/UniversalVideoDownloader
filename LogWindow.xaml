<Window x:Class="UniversalVideoDownloader.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Download Process Logs" Height="450" Width="650"
        Background="#0F172A" WindowStartupLocation="CenterOwner"
        BorderBrush="#1E293B" BorderThickness="1">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="DOWNLOAD LOG CONSOLE" FontSize="16" FontWeight="Bold" Foreground="#38BDF8"/>
            <TextBlock Text="{Binding Title, StringFormat='Active Item: {0}'}" FontSize="12" Foreground="#94A3B8" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Logs Terminal -->
        <Border Grid.Row="1" Background="#020617" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="12">
            <TextBox Name="LogTextBox" 
                     Text="{Binding LogContentText, Mode=OneWay}" 
                     IsReadOnly="True" 
                     TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" 
                     Background="Transparent" 
                     BorderThickness="0" 
                     Foreground="#10B981" 
                     FontFamily="Consolas" 
                     FontSize="12"
                     TextChanged="LogTextBox_TextChanged"/>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Copy Logs" 
                    Click="CopyLogs_Click" 
                    Width="100" Height="36" 
                    Background="#1E293B" Foreground="#E2E8F0" 
                    BorderThickness="0" Cursor="Hand" Margin="0,0,12,0">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Close" 
                    Click="Close_Click" 
                    Width="80" Height="36" 
                    Background="#38BDF8" Foreground="#0F172A" 
                    FontWeight="SemiBold" 
                    BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
